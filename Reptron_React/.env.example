# PowerFuel API (Swagger: http://gym-management-0.runasp.net/swagger/index.html)
VITE_API_BASE_URL=http://gym-management-0.runasp.net

# AI fitness coach backend
# Example local backend: http://localhost:8000
VITE_AI_API_BASE_URL=http://localhost:8000

# Optional API prefix for AI routes.
# Keep empty if backend exposes /start-session, /analyze-frame, ...
# Example: /api/FitnessCoach
VITE_AI_API_PREFIX=

# API key for fitness coach backend (maps to X-API-Key header)
VITE_AI_API_KEY=dev-secret
